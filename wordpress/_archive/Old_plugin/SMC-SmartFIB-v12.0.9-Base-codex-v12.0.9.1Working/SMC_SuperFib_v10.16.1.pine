//@version=6
const string INDICATOR_NAME = "SMC SuperFib"
const string INDICATOR_BUILD = "v12.0.9.1 - AM Bug Run"
indicator(INDICATOR_NAME + " " + INDICATOR_BUILD + " Smart Layout", overlay=true, max_lines_count=500, max_labels_count=500, max_boxes_count=500, max_bars_back=5000)

var GD = "Display"
session_tf_override_on = input.bool(false, "Override auto session", group=GD, display=display.none)
session_tf_override    = input.string("Yearly", "Session size (manual)", options=["Yearly","Monthly","Weekly","Daily"], group=GD, display=display.none)
_tf_secs_for_session = timeframe.in_seconds(timeframe.period)
_auto_session_tf =
     _tf_secs_for_session <= 3600   ? "Daily"   :
     _tf_secs_for_session <= 14400  ? "Weekly"  :
     _tf_secs_for_session <= 86400  ? "Monthly" : "Yearly"
session_tf = session_tf_override_on ? session_tf_override : _auto_session_tf
// v8: Authority TF is one session level above the active session (auto or override)
_authority_tf =
     session_tf == "Daily"   ? "Weekly"  :
     session_tf == "Weekly"  ? "Monthly" :
     session_tf == "Monthly" ? "Yearly"  : "Yearly"
pip_type          = input.string("USD",    "Pair type",       options=["USD","JPY"],                         group=GD, display=display.none)
show_bands        = input.bool(true,  "Zone tolerance bands",   group=GD, display=display.none)
show_chop         = input.bool(true,  "Chop zone fill",         group=GD, display=display.none)
show_labels       = input.bool(true,  "Fib level labels",       group=GD, display=display.none)
show_sf_1star     = input.bool(false, "Include 1-star zones",   group=GD, display=display.none)
show_ede_arrows   = input.bool(true,  "EDE directional arrows (2★+)", group=GD, display=display.none)
show_signals      = input.bool(true,  "Entry signal arrows",    group=GD, display=display.none)
show_regime       = input.bool(true,  "Regime labels + BOS/MSS",group=GD, display=display.none)
show_regime_bg    = input.bool(true,  "Regime background tint", group=GD, display=display.none)
show_killzones    = input.bool(false, "Kill zone shading",      group=GD, display=display.none)
show_period_lines = input.bool(false, "Period vertical lines",  group=GD, display=display.none)
show_line_year    = input.bool(true,  "  ↳ Yearly",            group=GD, display=display.none)
show_line_quarter = input.bool(true,  "  ↳ Quarterly",         group=GD, display=display.none)
show_line_month   = input.bool(true,  "  ↳ Monthly",           group=GD, display=display.none)
show_line_biweek  = input.bool(false, "  ↳ Biweekly",           group=GD, display=display.none)
