{
  "name": "@smc/superfib-sdk",
  "version": "0.1.0",
  "description": "SMC SuperFib Dashboard SDK — typed API client, domain types, utilities, and mock fixtures",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/types/index.js",
      "require": "./dist/types/index.cjs"
    },
    "./client": {
      "types": "./dist/client/index.d.ts",
      "import": "./dist/client/index.js",
      "require": "./dist/client/index.cjs"
    },
    "./utils": {
      "types": "./dist/utils/index.d.ts",
      "import": "./dist/utils/index.js",
      "require": "./dist/utils/index.cjs"
    },
    "./constants": {
      "types": "./dist/constants/index.d.ts",
      "import": "./dist/constants/index.js",
      "require": "./dist/constants/index.cjs"
    },
    "./mocks": {
      "types": "./dist/mocks/index.d.ts",
      "import": "./dist/mocks/index.js",
      "require": "./dist/mocks/index.cjs"
    },
    "./auth": {
      "types": "./dist/auth/index.d.ts",
      "import": "./dist/auth/index.js",
      "require": "./dist/auth/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "dev": "vite build --watch"
  },
  "devDependencies": {
    "typescript": "^5.8.3",
    "vite": "^7.3.1"
  },
  "keywords": [
    "smc",
    "trading",
    "fibonacci",
    "forex",
    "mt5",
    "smart-money-concepts",
    "typescript-sdk",
    "superfib"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/klintaruvinga-png/smcsmartfib-WebApp"
  },
  "author": "klintaruvinga-png",
  "license": "UNLICENSED"
}
